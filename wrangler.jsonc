{
  "main": "dist/_worker.js/index.js",
  "name": "astropage",
  // Update to today's date
  // Set this to today's date
  "compatibility_date": "2026-04-19",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}