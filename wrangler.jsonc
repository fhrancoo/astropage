{
  "name": "astropage",
  "main": "./dist/_worker.js/index.js",
  // Update to today's date
  // Set this to today's date
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}